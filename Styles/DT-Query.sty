\def\querynote{\@ifnextchar[\@xquerynote{\stepcounter{querynote}\addtocounter{MSquerynotedisplay}{1}%
     \protected@xdef\@thequerymark{\thequerynote}%
     \@querynotemark\@querynotetext}}

\def\@xquerynote[#1]{%
   \begingroup
     \c@querynote=#1\relax
     \unrestored@protected@xdef\@thequerymark{\thequerynote}%
   \endgroup
   \@querynotemark\@querynotetext}

%  Here begins a section of querynote code that's really different from
% the footnote code of LaTeX.

\let\@doanqnote=0
\let\@endanqnote=0

\newwrite\@qnotes
\newif\if@qnotesopen \global\@qnotesopenfalse

\def\@openqnotes{\immediate\openout\@qnotes=\jobname.qry\relax
      \global\@qnotesopentrue}

%  The stuff with \next and \meaning is a trick from the TeXbook, 382,
% there intended for setting verbatim text, but here used to avoid
% macro expansion when the footnote text is written.  \next will have
% the entire text of the footnote as one long line, which might well
% overflow limits on output line length; the business with \newlinechar
% makes every space become a newline in the \@qnotes file, so that all
% of the lines wind up being quite short.

\long\def\@querynotetext#1{%
     \if@qnotesopen \else \@openqnotes \fi
     \immediate\write\@qnotes{\@doanqnote{\@thequerymark}}%
     \begingroup
        \def\next{#1}%
        \newlinechar='40
        \immediate\write\@qnotes{\meaning\next}%
     \endgroup
     \immediate\write\@qnotes{\@endanqnote}}

% \addtoquerynotes works the way the other querynote macros probably should
% have, requiring the use of \protect for fragile commands.

\long\def\addtoquerynotes#1{%
     \if@qnotesopen \else \@openqnotes \fi
     \begingroup
        \newlinechar='40
        \let\protect\string
        \immediate\write\@qnotes{#1}%
     \endgroup}

%  End of unique querynote code

\def\querynotemark{%
   \@ifnextchar[\@xquerynotemark
     {\stepcounter{querynote}\addtocounter{MSquerynotedisplay}{1}%
      \protected@xdef\@thequerymark{\thequerynote}%
      \@querynotemark}}

\def\@xquerynotemark[#1]{%
   \begingroup
      \c@querynote #1\relax
      \unrestored@protected@xdef\@thequerymark{\thequerynote}%
   \endgroup
   \@querynotemark}

