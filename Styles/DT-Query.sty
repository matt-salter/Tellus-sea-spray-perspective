               \rlap{\kern\hsize\kern\marginparsep\kern\querymarginnoterightadjust
               \vbox to\z@{\kern #3
               \vbox to\z@{%
               \hsize\marginparwidth
               \kern-\baselineskip\kern-\parskip
               \marginfont\raggedrightquerymarginnote\hspace{\z@}\strut#2\endgraf
               \vss}%
               \vss}%
       }%
               \else
