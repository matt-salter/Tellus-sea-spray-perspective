   \newcommand{\@mn@@@querymarginnote}{}
   \def\@mn@@@querymarginnote[#1]#2[#3]{%
           \begingroup
           \ifmmode\strut\let\@tempa\vadjust\else
       \if@inlabel\leavevmode\fi
               \ifhmode\strut\let\@tempa\vadjust\else\let\@tempa\mn@vlap\fi
               \fi
