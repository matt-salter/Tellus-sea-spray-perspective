               \kern-\baselineskip\kern-\parskip
               \marginfont\raggedleftquerymarginnote\hspace{\z@}\strut#1\endgraf
               \vss}%
               \vss}%
               \kern\marginparsep\kern\querymarginnoteleftadjust
       }%
               \fi
       }%
       }%
