%  \thequerynotes actually prints out the querynotes.

%  The user may want separate querynotes for each chapter, or a big
% block of them at the end of the whole document.  As it stands,
% either will work; you just say \thequerynotes wherever you want the
% querynotes so far to be inserted.  However, you must add
% \setcounter{querynote}{0} after that if you want subsequent querynotes
% to start numbering at 1 again.

%  \qnoteformat is provided so user can specify some special formatting
% for the querynotes.  It needs to set up the paragraph parameters, start
% the paragraph, and print the label.  The \mbox stuff in \qnoteheading
% is to make and undo a dummy paragraph, to get around the games \section*
% plays with paragraph indenting and instead give us uniform
% indenting for all notes.

\def\qnoteheading{\section*{\qnotesname
  \@mkboth{\MakeUppercase{\qnotesname}}{\MakeUppercase{\qnotesname}}}%
  \mbox{}\par\vskip-\baselineskip}

\def\hangfrom#1{\setbox\@tempboxa=\hbox{#1}%
  \addtolength{\hangindent}{\wd\@tempboxa}%
  \hangafter=1\unhbox\@tempboxa}

\def\qnoteformat{\rightskip\z@ \leftskip\z@ \parindent=0em
  \leavevmode\hangfrom{\hbox to 26pt{\makequerymark}}}

\def\qnotesize{\normalsize}

\def\thequerynotes{\immediate\closeout\@qnotes \global\@qnotesopenfalse
  \begingroup
  \onecolumn\clearpage
  \pagestyle{empty}
  \thispagestyle{empty}
    \makeatletter
    %
    % The machinery with \@ResetGT and > here ensures that
    % \@doanqnote works properly even if > is an active character
    % at the point where \thequerynotes is invoked. > needs to have
    % catcode 12 when the arguments of \@doanqnote are scanned, so
    % that the > in the string "macro:->" is matched.  The actual
    % footnote text is not an argument to \@doanqnote, but just
    % follows it in the .qry file; so \@ResetGT can reset the
    % category code for > that should be used when processing
    % that text.  That resetting takes place within a
    % \begingroup-\endgroup block set up by \@doanqnote and
    % \@endanqnote, so the catcode for > is back to 12 for the
    % next note.
    %
    \edef\@tempa{`\string >}%
    \ifnum\catcode\@tempa=12%
      \let\@ResetGT\relax
    \else
      \edef\@ResetGT{\noexpand\catcode\@tempa=\the\catcode\@tempa}%
      \@makeother\>%
    \fi
    \def\@doanqnote##1##2>{\def\@thequerymark{##1}\par\begingroup
        \@ResetGT
        \edef\@currentlabel{\csname p@querynote\endcsname\@thequerymark}%
        \qnoteformat}
    \def\@endanqnote{\par\endgroup}%
    \qnoteheading
    \qnotesize
  \pagestyle{empty}
  \thispagestyle{empty}
    \input{\jobname.qry}%
  \pagestyle{empty}
  \thispagestyle{empty}
  \endgroup}

